{
  "name": "jobhunt-cli",
  "version": "0.1.9",
  "description": "Search, export, and analyze public company recruitment jobs.",
  "homepage": "https://github.com/Enzoding/JobHunt-CLI#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Enzoding/JobHunt-CLI.git"
  },
  "bugs": {
    "url": "https://github.com/Enzoding/JobHunt-CLI/issues"
  },
  "type": "module",
  "main": "./index.js",
  "bin": {
    "job": "bin/job.js",
    "jobhunt-cli": "bin/job.js"
  },
  "exports": {
    ".": "./index.js",
    "./opencli": "./integrations/opencli/index.js"
  },
  "files": [
    "bin/",
    "docs/",
    "integrations/",
    "skills/",
    "src/",
    "index.js",
    "opencli.js",
    "opencli-plugin.json",
    "README.md"
  ],
  "engines": {
    "node": ">=21.0.0"
  },
  "dependencies": {
    "commander": "^14.0.3",
    "undici": "^8.1.0"
  },
  "peerDependencies": {
    "@jackwener/opencli": ">=1.0.0"
  },
  "peerDependenciesMeta": {
    "@jackwener/opencli": {
      "optional": true
    }
  },
  "scripts": {
    "job": "node bin/job.js",
    "smoke:kuaishou": "node scripts/smoke-kuaishou-api.js",
    "smoke:didi": "node scripts/smoke-didi-api.js",
    "smoke:bytedance": "node scripts/smoke-bytedance-api.js",
    "smoke:meituan": "node scripts/smoke-meituan-api.js",
    "smoke:xiaomi": "node scripts/smoke-xiaomi-api.js",
    "smoke:tencent": "node scripts/smoke-tencent-api.js",
    "smoke:baidu": "node scripts/smoke-baidu-api.js",
    "smoke:jd": "node scripts/smoke-jd-api.js",
    "smoke:xiaohongshu": "node scripts/smoke-xiaohongshu-api.js",
    "smoke:bilibili": "node scripts/smoke-bilibili-api.js",
    "smoke:netease": "node scripts/smoke-netease-api.js",
    "smoke:ctrip": "node scripts/smoke-ctrip-api.js",
    "smoke:huawei": "node scripts/smoke-huawei-api.js",
    "smoke:dji": "node scripts/smoke-dji-api.js",
    "smoke:ant": "node scripts/smoke-ant-api.js",
    "smoke:dewu": "node scripts/smoke-dewu-api.js",
    "smoke:mihoyo": "node scripts/smoke-mihoyo-api.js",
    "smoke:minimax": "node scripts/smoke-minimax-api.js",
    "smoke:moonshot": "node scripts/smoke-moonshot-api.js",
    "smoke:zhipu": "node scripts/smoke-zhipu-api.js",
    "smoke:alibaba-cpo": "node scripts/smoke-alibaba-cpo-api.js",
    "smoke": "npm run smoke:kuaishou && npm run smoke:didi && npm run smoke:bytedance && npm run smoke:meituan && npm run smoke:xiaomi && npm run smoke:tencent && npm run smoke:baidu && npm run smoke:jd && npm run smoke:xiaohongshu && npm run smoke:bilibili && npm run smoke:netease && npm run smoke:ctrip && npm run smoke:huawei && npm run smoke:dji && npm run smoke:ant && npm run smoke:dewu && npm run smoke:mihoyo && npm run smoke:minimax && npm run smoke:moonshot && npm run smoke:zhipu && npm run smoke:alibaba-cpo",
    "smoke:cli": "node bin/job.js xiaomi search AI --limit 1 --format json"
  },
  "keywords": [
    "cli",
    "kuaishou",
    "didi",
    "bytedance",
    "meituan",
    "xiaomi",
    "tencent",
    "baidu",
    "jd",
    "xiaohongshu",
    "bilibili",
    "netease",
    "ctrip",
    "huawei",
    "dji",
    "alibaba",
    "aliyun",
    "cainiao",
    "jobs",
    "recruitment",
    "job-search"
  ],
  "license": "MIT",
  "publishConfig": {
    "registry": "https://registry.npmjs.org"
  }
}
